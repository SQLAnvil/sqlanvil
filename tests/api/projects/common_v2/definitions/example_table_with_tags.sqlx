config {
  type: "table",
  tags: ["tag1", "tag2", "tag3"],
  assertions: {
    uniqueKey: ["sample"],
    nonNull: ["sample"]
  },
  disabled: true
}

select * from ${ref("sample_data")}

post_operations {
    GRANT SELECT ON ${self()} TO GROUP "allusers@example.com"
    ---
    GRANT SELECT ON ${self()} TO GROUP "otherusers@example.com"
}
