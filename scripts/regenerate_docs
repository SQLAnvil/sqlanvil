#!/bin/bash
set -euo pipefail

####################################################################################################
# Regenerate the SQLAnvil reference docs:
#   * Javascript API class pages (typedoc)  -> reference/<action>.md
#   * protobuf config reference (camelCase)  -> reference/configs.md
#
# These publish straight into the Starlight site (sqlanvil-com) — the single canonical home for
# user-facing docs (sqlanvil.com/docs). Clone it as a sibling (../sqlanvil-com) or set COM_REPO.
#   git clone git@github.com:SQLAnvil/sqlanvil-com.git ../sqlanvil-com
# Each generated page replaces only the BODY of the existing Starlight page; its front matter
# (title/description/sidebar) is preserved.
####################################################################################################

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
COM_REPO="${COM_REPO:-../sqlanvil-com}"
COM_REF_REL="src/content/docs/docs/reference"
COM_REF="${COM_REPO}/${COM_REF_REL}"

if [ ! -d "${COM_REF}" ]; then
  echo "ERROR: ${COM_REF} not found. Clone the site repo: git clone git@github.com:SQLAnvil/sqlanvil-com.git ${COM_REPO}"
  exit 1
fi
COM_REF="$(cd "${COM_REF}" && pwd)"

# Generated bodies (plain markdown, no front matter) are written here, then applied into the
# Starlight pages with their front matter preserved. NB: must live OUTSIDE typedoc's `newdocs`
# out dir — typedoc refuses to write into a pre-existing directory it didn't generate.
GEN_DIR="${REPO_ROOT}/.docs_gen"
mkdir -p "${GEN_DIR}"

# Replace the body of a Starlight page while preserving its leading `--- ... ---` front matter.
# $1 = generated body file (plain markdown), $2 = target page in COM_REF.
apply_to_site() {
  local body="$1" target="$2"
  if [ -f "${target}" ] && head -1 "${target}" | grep -q '^---$'; then
    awk 'NR==1{print;next} /^---$/{print;exit} {print}' "${target}" > "${target}.tmp"
    printf '\n' >> "${target}.tmp"
    cat "${body}" >> "${target}.tmp"
    mv "${target}.tmp" "${target}"
  else
    cp "${body}" "${target}"
  fi
}

####################################################################################################
# Javascript API class pages (typedoc + post-processing).
####################################################################################################

# typedoc compiles core/** and must resolve the Bazel-generated `sa/protos/ts` and
# `sa/core/version` modules. Copy the two generated files out of bazel-bin for the duration
# of the run. (Requires a prior `bazel build //protos:ts //core:version` — native Bazel works
# on macOS since the bzlmod migration, #41; docker-bazel is no longer needed here.)
cleanup() { rm -f "${REPO_ROOT}/protos/ts.d.ts" "${REPO_ROOT}/core/version.ts"; rm -rf "${REPO_ROOT}/newdocs" "${REPO_ROOT}/.docs_gen"; }
trap cleanup EXIT

for f in protos/ts.d.ts core/version.ts; do
  [ -e "${REPO_ROOT}/bazel-bin/${f}" ] || { echo "bazel-bin/${f} missing — run: bazel build //protos:ts //core:version" >&2; exit 1; }
  cp -L "${REPO_ROOT}/bazel-bin/${f}" "${REPO_ROOT}/${f}"
  chmod 644 "${REPO_ROOT}/${f}"
done

( cd "${REPO_ROOT}" && npx typedoc )

# typedoc filename stem -> published slug. Post-process each into a flat, link-clean page.
PAGES="
session:_core_session_.session
assertion:_core_actions_assertion_.assertion
table:_core_actions_table_.table
view:_core_actions_view_.view
incrementaltable:_core_actions_incremental_table_.incrementaltable
operation:_core_actions_operation_.operation
notebook:_core_actions_notebook_.notebook
test:_core_actions_test_.test
declaration:_core_actions_declaration_.declaration
export:_core_actions_export_.export
import:_core_actions_import_.import
"
for entry in ${PAGES}; do
  slug="${entry%%:*}"; stem="${entry##*:}"
  src="${REPO_ROOT}/newdocs/classes/${stem}.md"
  [ -f "${src}" ] || { echo "WARNING: typedoc did not emit ${stem}.md — skipping ${slug}"; continue; }
  python3 "${SCRIPT_DIR}/../tools/typedoc/postprocess.py" "${src}" "${slug}" > "${GEN_DIR}/${slug}.md"
  apply_to_site "${GEN_DIR}/${slug}.md" "${COM_REF}/${slug}.md"
done
echo "Generated JS-API reference pages into ${COM_REF}"

####################################################################################################
# protobuf config reference (reference/configs.md).
####################################################################################################

# sqlx config keys are camelCase, so the proto reference must be generated with camelCase field
# names. Upstream pseudomuto/protoc-gen-doc only emits snake_case (the camel_case_fields option
# from PR #540 was never merged), so we build the Ekrekr fork's camelCase branch into a local
# image — see tools/protoc-gen-doc/.
IMAGE="${PROTOC_GEN_DOC_IMAGE:-protoc-gen-doc:camelcase}"
if ! docker image inspect "${IMAGE}" >/dev/null 2>&1; then
  echo "Image ${IMAGE} not found — building it..."
  "${REPO_ROOT}/tools/protoc-gen-doc/build-image.sh"
fi

docker run --rm \
  -v "${GEN_DIR}:/out" \
  -v "${REPO_ROOT}/protos:/protos" \
  "${IMAGE}" --doc_opt=markdown,configs.md::camel_case_fields=true configs.proto
apply_to_site "${GEN_DIR}/configs.md" "${COM_REF}/configs.md"
echo "Generated configs.md into ${COM_REF}"
